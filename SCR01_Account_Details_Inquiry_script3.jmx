<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="SCR01_Account_Details_Inquiry">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="dp_host" elementType="Argument">
            <stringProp name="Argument.name">dp_host</stringProp>
            <stringProp name="Argument.value">bds-ui-nft.citysavings.net</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_port" elementType="Argument">
            <stringProp name="Argument.name">dp_port</stringProp>
            <stringProp name="Argument.value">443</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_protocol" elementType="Argument">
            <stringProp name="Argument.name">dp_protocol</stringProp>
            <stringProp name="Argument.value">https</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="==========================================================" elementType="Argument">
            <stringProp name="Argument.name">==========================================================</stringProp>
            <stringProp name="Argument.value">=======================================================</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_filepath" elementType="Argument">
            <stringProp name="Argument.name">dp_filepath</stringProp>
            <stringProp name="Argument.value">${__BeanShell(import org.apache.jmeter.services.FileServer;FileServer.getFileServer().getBaseDir();)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_filedate" elementType="Argument">
            <stringProp name="Argument.name">dp_filedate</stringProp>
            <stringProp name="Argument.value">${__time(yyyy-MM-dd,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="===========================================================" elementType="Argument">
            <stringProp name="Argument.name">===========================================================</stringProp>
            <stringProp name="Argument.value">=========================================================</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SCR01_Pacing" elementType="Argument">
            <stringProp name="Argument.name">SCR01_Pacing</stringProp>
            <stringProp name="Argument.value">0</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_thinktime_low" elementType="Argument">
            <stringProp name="Argument.name">dp_thinktime_low</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_thinktime_high" elementType="Argument">
            <stringProp name="Argument.name">dp_thinktime_high</stringProp>
            <stringProp name="Argument.value">3</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="===========================================================" elementType="Argument">
            <stringProp name="Argument.name">===========================================================</stringProp>
            <stringProp name="Argument.value">=======================================================</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SCR01_thread" elementType="Argument">
            <stringProp name="Argument.name">SCR01_thread</stringProp>
            <stringProp name="Argument.value">5</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dp_rampup" elementType="Argument">
            <stringProp name="Argument.name">dp_rampup</stringProp>
            <stringProp name="Argument.value">5</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SCR01_iteration" elementType="Argument">
            <stringProp name="Argument.name">SCR01_iteration</stringProp>
            <stringProp name="Argument.value">10</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <CookieManager guiclass="CookiePanel" testclass="CookieManager" testname="HTTP Cookie Manager">
        <collectionProp name="CookieManager.cookies"/>
        <boolProp name="CookieManager.clearEachIteration">true</boolProp>
        <boolProp name="CookieManager.controlledByThreadGroup">false</boolProp>
      </CookieManager>
