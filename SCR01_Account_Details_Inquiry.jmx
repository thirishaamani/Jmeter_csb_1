              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="SCR01_Pacing_Sampler" enabled="true">
                <stringProp name="cacheKey">false</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">import java.text.ParseException;
import java.text.SimpleDateFormat;
import java.lang.Math;	
	try {

	SimpleDateFormat format = new SimpleDateFormat(&quot;HH:mm:ss.S&quot;);
	//SimpleDateFormat format = new SimpleDateFormat();
	java.util.Date date1=format.parse(&quot;${TimeS}&quot;);
	java.util.Date date2=format.parse(&quot;${TimeE}&quot;);
	log.info(&quot;starttime:&quot;+date1);
	log.info(&quot;endtime:&quot;+date2);
	difference =date2.getTime() - date1.getTime();
	diff = difference/1000;
	diff = Math.abs(diff);
	log.info(&quot;differencetime:&quot;+diff);
	//log.info(Long.toString(diff));

	pacing=2000;
	if(diff&lt;${SCR01_Pacing})
	{
		pacing= (${SCR01_Pacing} - diff)*1000;
	}
	//pacing= (${SVS02_Pacing})*1000;
	log.info(&quot;pacingtime:&quot;+pacing);
	vars.put(&quot;DC_Pacing&quot;,pacing.toString());

	
	
	}catch(Exception e)
	{
		e.printStackTrace();
	}
</stringProp>
                <stringProp name="scriptLanguage">java</stringProp>
              </JSR223Sampler>
