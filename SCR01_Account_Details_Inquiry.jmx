          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Filewrite" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.io.*
import org.apache.jmeter.services.FileServer

def username = vars.get(&quot;dp_username&quot;)
def branchno = vars.get(&quot;dp_branchno&quot;)
def txn = vars.get(&quot;dc_global_transaction_num&quot;)
def fileDate = vars.get(&quot;dp_filedate&quot;)
def filePath = vars.get(&quot;dp_filepath&quot;)

def dir = new File(filePath + &quot;/Filewrite&quot;)
dir.mkdirs()

def file = new File(filePath + &quot;/Filewrite/SCR01_Account_Details_Inquiry_&quot; + fileDate + &quot;.txt&quot;)

// Write header once
if (!file.exists() || file.length() == 0) {
    file &lt;&lt; &quot;username,branch,globalseqno\n&quot;
}

// Append data
file &lt;&lt; &quot;${username},${branchno},${txn}\n&quot;
</stringProp>
          </JSR223Sampler>
